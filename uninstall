#!/usr/bin/env bash
set -euo pipefail

# Uninstallation script for lazypacman

echo "Uninstalling lazypacman..."

# Remove symlink
if [[ -L "$HOME/.local/bin/pkg" ]]; then
    rm "$HOME/.local/bin/pkg"
    echo "✓ Removed $HOME/.local/bin/pkg"
fi

# Remove cache
if [[ -d "$HOME/.cache/lazypacman" ]]; then
    rm -rf "$HOME/.cache/lazypacman"
    echo "✓ Removed $HOME/.cache/lazypacman"
fi

# Remove installation directory (if installed via curl)
if [[ -d "$HOME/.local/share/lazypacman" ]]; then
    read -rp "Remove $HOME/.local/share/lazypacman? (Y/N): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        rm -rf "$HOME/.local/share/lazypacman"
        echo "✓ Removed $HOME/.local/share/lazypacman"
    fi
fi

echo
echo "Uninstallation complete!"
