#!/usr/bin/env bash
set -euo pipefail

#  _                    ____                                  
# | |    __ _ _____   _|  _ \ __ _  ___ _ __ ___   __ _ _ __  
# | |   / _` |_  / | | | |_) / _` |/ __| '_ ` _ \ / _` | '_ \ 
# | |__| (_| |/ /| |_| |  __/ (_| | (__| | | | | | (_| | | | |
# |_____\__,_/___|\__, |_|   \__,_|\___|_| |_| |_|\__,_|_| |_|
#                 |___/                                
# 
# Fast TUI + CLI package manager wrapper for Arch Linux
# Author: Andrianos Papamarkou
# email: papamarkoua@gmail.com
#
# Installation script for lazypacman


INSTALL_DIR="$HOME/.local/bin"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_SCRIPT="$SCRIPT_DIR/src/pkg"

echo "Installing pkg..."

# Create install directory
mkdir -p "$INSTALL_DIR"

# Create symlink
ln -sf "$PKG_SCRIPT" "$INSTALL_DIR/pkg"

# Make executable
chmod +x "$PKG_SCRIPT"

echo "✓ Installed to $INSTALL_DIR/pkg"

# Check if in PATH
if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    echo
    echo "Warning: $INSTALL_DIR is not in your PATH"
    echo "Add this to your ~/.bashrc or ~/.zshrc:"
    echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
fi

# Check dependencies
echo
echo "Checking dependencies..."
missing=()
for dep in pacman yay fzf jq curl pacman-contrib most; do
    if ! command -v "$dep" &>/dev/null; then
        missing+=("$dep")
    fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "✗ Missing dependencies: ${missing[*]}"
    echo "  Install with: sudo pacman -S ${missing[*]}"
    exit 1
else
    echo "✓ All dependencies found"
fi

echo
echo "Installation complete! Run 'pkg' to start."
