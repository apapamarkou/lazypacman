# Main entry point for pkg

# Determine script directory
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
MODULE_DIR="$SCRIPT_DIR"

# Load core modules
# shellcheck source=src/core/loader.sh
source "$MODULE_DIR/core/loader.sh"

require core/config
require core/colors
require core/utils
require core/prompt
require cache/cache
require system/dependencies
require system/updates
require system/orphan_cleaner
require pacman/pacman
require tui/preview
require tui/actions
require tui/tui
require cli/help
require cli/commands
require cli/parser

# Check dependencies
check_dependencies || exit 1

# Main logic
if [[ $# -eq 0 ]]; then
    # No arguments - launch TUI
    launch_tui
else
    # CLI mode
    parse_cli "$@"
fi
